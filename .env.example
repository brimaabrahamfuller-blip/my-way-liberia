# Database Configuration
# For PostgreSQL with connection pooling (recommended for Vercel)
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# Direct database URL (for migrations, bypasses connection pooling)
DIRECT_URL="postgresql://user:password@direct-host:port/database?schema=public"

# NextAuth Configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-min-32-characters"
NEXTAUTH_URL="http://localhost:3000"

# Anthropic AI Configuration
# Get your API key from: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Optional: Email Configuration
# For sending emails (optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@myway.com"

# Optional: AWS S3 Configuration
# For file uploads (optional)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="myway-liberia-uploads"

# Application Configuration
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="Myway"
NEXT_PUBLIC_APP_DESCRIPTION="Career Platform for Liberia"

# Optional: Analytics
# For tracking and analytics (optional)
NEXT_PUBLIC_ANALYTICS_ID=""

# Optional: Sentry Error Tracking
# For error tracking (optional)
SENTRY_AUTH_TOKEN=""
