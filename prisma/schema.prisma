// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User model
model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  password      String?
  image         String?
  role          String    @default("STUDENT") // STUDENT, EMPLOYER, COUNSELOR
  isPremium     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  applications  JobApplication[]
  savedJobs     SavedJob[]
  mentorships   MentorshipRequest[]
  messages      Message[]
  education     Education[]
  experience    Experience[]
  resume        Resume?

  @@index([email])
  @@index([role])
  @@map("users")
}

// NextAuth Account model
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// NextAuth Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// NextAuth Verification Token model
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Job model
model Job {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  company     String
  location    String
  salary      String?
  jobType     String   // FULL_TIME, PART_TIME, CONTRACT, INTERNSHIP
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications JobApplication[]
  savedBy      SavedJob[]

  @@index([company])
  @@index([createdAt])
  @@map("jobs")
}

// Job Application model
model JobApplication {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  appliedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@index([status])
  @@map("job_applications")
}

// Saved Job model
model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  savedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@map("saved_jobs")
}

// Mentorship Request model
model MentorshipRequest {
  id        String   @id @default(cuid())
  studentId String
  mentorId  String
  status    String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  message   String?  @db.Text
  createdAt DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
  @@map("mentorship_requests")
}

// Message model
model Message {
  id        String   @id @default(cuid())
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("messages")
}

// Education model
model Education {
  id        String   @id @default(cuid())
  userId    String
  school    String
  degree    String
  field     String
  startYear Int
  endYear   Int?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("education")
}

// Experience model
model Experience {
  id          String   @id @default(cuid())
  userId      String
  company     String
  title       String
  startDate   DateTime
  endDate     DateTime?
  description String?  @db.Text
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("experience")
}

// Resume model
model Resume {
  id        String   @id @default(cuid())
  userId    String   @unique
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resumes")
}
